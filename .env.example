# Required for the /contact form to send enquiries.
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: override the recipient address. Defaults to giulio@aioncover.com.
# While your sending domain is unverified, Resend's test sender can only
# deliver to the email registered with your Resend account.
# CONTACT_TO_EMAIL=

# Optional: from address shown in the email.
# Must be a verified sender on Resend (default = onboarding@resend.dev for testing).
# CONTACT_FROM_EMAIL="AION Cover <hello@aioncover.com>"
